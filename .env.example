# ============================================
# EduContent Pipeline — Environment Variables
# ============================================
# Copy this file to config/.env and fill in your values.

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Notion Integration Token (Internal Integration)
NOTION_TOKEN=your_notion_internal_integration_token_here

# Gemini API Key (for AI thumbnail generation)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (for LLM-powered transcript enhancement)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: ScrapeCreators API Key (for competitor thumbnail scraping)
SCRAPECREATORS_API_KEY=your_scrapecreators_api_key_here

# Optional: TTS Colab Notebook URL (defaults to Qwen3; set to CosyVoice 2 notebook URL to switch)
# TTS_COLAB_URL=https://colab.research.google.com/drive/YOUR_COSYVOICE2_NOTEBOOK_ID
